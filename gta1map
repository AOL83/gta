    function updateHUD(){ modeText.textContent=sceneMode==='interior'?'Interior walking':(mode==='walking'?'Walking':'Driving'); districtText.textContent=currentDistrict(); const speed=mode==='walking'?playerVelocity.length():Math.abs(activeCar?.userData.speed||0); speedText.textContent=speed.toFixed(1); healthText.textContent=Math.round(gameState.health); healthBar.style.width=`${gameState.health}%`; moneyText.textContent=gameState.money; wantedText.textContent='★'.repeat(gameState.wanted)+'☆'.repeat(5-gameState.wanted); if(sceneMode==='interior'){carText.textContent='No vehicles'; const action=nearestInteractive(); nearbyText.textContent=action?.type==='exit'?'Exit tower (E)':action?.type==='floor-up'?'Stairwell up (E)':action?.type==='floor-down'?'Stairwell down (E)':`Exploring ${currentInterior}`; } else {const near=nearestCar(); carText.textContent=near.car?`${near.dist.toFixed(1)}m ${near.dist<6?'(Press E)':''}`:'None'; const action=nearestInteractive(); const metro=nearestMetro(); if(action?.type==='tower-door')nearbyText.textContent=`Tower ${action.tower} entrance (E)`; else if(metro&&metro.dist<18)nearbyText.textContent=`Metro entrance: ${metro.name}`; else nearbyText.textContent='City grid';} if(!pointerLocked&&!pointerLockAvailable)lookText.textContent='Drag fallback'; }
    function worldToMap(x,z){const s=miniMap.width;return{x:((x+HALF_WORLD)/WORLD_SIZE)*s,y:((z+HALF_WORLD)/WORLD_SIZE)*s};}
    function drawTriangle(ctx,x,y,a,s,c){ctx.save();ctx.translate(x,y);ctx.rotate(-a);ctx.fillStyle=c;ctx.beginPath();ctx.moveTo(0,-s);ctx.lineTo(s*.65,s);ctx.lineTo(-s*.65,s);ctx.closePath();ctx.fill();ctx.restore();}
    function updateMiniMap(){ const w=miniMap.width,h=miniMap.height; miniCtx.clearRect(0,0,w,h); miniCtx.fillStyle='rgba(3,15,22,.96)'; miniCtx.fillRect(0,0,w,h); if(sceneMode==='interior'){ miniCtx.fillStyle='rgba(30,45,55,.95)'; miniCtx.fillRect(18,18,w-36,h-36); miniCtx.strokeStyle='rgba(0,255,170,.45)'; miniCtx.strokeRect(18,18,w-36,h-36); miniCtx.fillStyle='#ffee55'; miniCtx.fillText(`${currentInterior} F${interiorFloor}`,16,14); const px=THREE.MathUtils.mapLinear(player.position.x,-45,45,18,w-18), py=THREE.MathUtils.mapLinear(player.position.z,-45,45,18,h-18); drawTriangle(miniCtx,px,py,player.rotation.y,6,'#00ffaa'); return; } miniCtx.fillStyle='rgba(22,60,38,.95)'; for(const d of districts){const p=worldToMap(d.x-d.halfX,d.z-d.halfZ),p2=worldToMap(d.x+d.halfX,d.z+d.halfZ);miniCtx.fillRect(p.x,p.y,p2.x-p.x,p2.y-p.y);} for(const r of roads){const p=worldToMap(r.x-r.w/2,r.z-r.d/2),p2=worldToMap(r.x+r.w/2,r.z+r.d/2);miniCtx.fillStyle=r.kind==='highway'?'rgba(255,238,85,.45)':'rgba(255,255,255,.2)';miniCtx.fillRect(p.x,p.y,p2.x-p.x,p2.y-p.y);} miniCtx.fillStyle='rgba(255,238,85,.75)'; [{x:-310,z:-130},{x:-190,z:-130}].forEach(t=>{const p=worldToMap(t.x,t.z);miniCtx.fillRect(p.x-3,p.y-3,6,6)}); miniCtx.fillStyle='rgba(0,255,170,.22)'; for(const m of metroEntrances){const p=worldToMap(m.x,m.z);miniCtx.beginPath();miniCtx.arc(p.x,p.y,3.2,0,Math.PI*2);miniCtx.fill();} for(const car of cars){const p=worldToMap(car.position.x,car.position.z);drawTriangle(miniCtx,p.x,p.y,car.rotation.y,car===activeCar?5:3.5,car===activeCar?'#ffee55':'#ff5577');} const target=mode==='walking'?player:activeCar,p=worldToMap(target.position.x,target.position.z);drawTriangle(miniCtx,p.x,p.y,mode==='walking'?player.rotation.y:activeCar.rotation.y,5.5,'#00ffaa'); miniCtx.strokeStyle='rgba(0,255,170,.5)'; miniCtx.lineWidth=2; miniCtx.strokeRect(1,1,w-2,h-2); }
    function runSelfTests(){ const tests=[],assert=(n,c)=>tests.push({name:n,pass:Boolean(c)}); assert('THREE loaded',typeof THREE.Scene==='function'); assert('large world active',WORLD_SIZE>=2000); assert('twin tower doors created',interactiveZones.filter(z=>z.type==='tower-door').length===2); assert('metro entrances created',metroEntrances.length>=5); assert('enterable tower placeholders exist',interiorDoors.filter(d=>d.type==='tower').length===2); assert('cars created',cars.length>=8); assert('interior loader exists',typeof enterTower==='function'); assert('floor changing exists',typeof changeFloor==='function'); assert('minimap canvas exists',miniMap instanceof HTMLCanvasElement); assert('pointer lock guarded',typeof tryPointerLock==='function'); const failed=tests.filter(t=>!t.pass); console.table(tests); testBadge.textContent=failed.length?`Self-tests failed: ${failed.length}`:`Self-tests passed: ${tests.length}`; testBadge.style.color=failed.length?'#ffb3b3':'#baffea'; return{total:tests.length,failed}; }
    function animate(){ requestAnimationFrame(animate); const dt=Math.min(clock.getDelta(),.05); if(mode==='walking')updateWalking(dt); else updateDriving(dt); updateCamera(dt); updateHUD(); updateMiniMap(); renderer.render(scene,camera); }
    window.addEventListener('resize',()=>{camera.aspect=window.innerWidth/window.innerHeight;camera.updateProjectionMatrix();renderer.setSize(window.innerWidth,window.innerHeight);}); window.__AURORA_STAGE31_TESTS__=runSelfTests; runSelfTests(); showMessage('Stage 3.1 loaded — Twin Towers with explorable streamed interiors'); animate();
  </script>
