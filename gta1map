    function currentDistrict(){ if(sceneMode==='interior')return `${currentInterior} — Floor ${interiorFloor}`; const pos=mode==='walking'?player.position:activeCar?.position; const d=districts.find(r=>Math.abs(pos.x-r.x)<=r.halfX&&Math.abs(pos.z-r.z)<=r.halfZ); return d?d.name:'Waterfront / Crossing'; }
