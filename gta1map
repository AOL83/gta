<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Aurora Stage 3.1 — Twin Tower Interior Prototype</title>
  <style>
    * { box-sizing: border-box; }
    html, body { margin:0; width:100%; height:100%; overflow:hidden; background:#05070a; font-family:Arial,Helvetica,sans-serif; color:white; user-select:none; touch-action:none; }
    canvas { display:block; }
    #hud { position:fixed; top:0; left:0; right:0; pointer-events:none; padding:14px; display:flex; justify-content:space-between; align-items:flex-start; z-index:10; gap:12px; }
    .panel { background:rgba(0,0,0,.58); border:1px solid rgba(0,255,170,.35); box-shadow:0 0 18px rgba(0,255,170,.18); border-radius:14px; padding:12px 14px; backdrop-filter:blur(8px); max-width:430px; }
    .title { font-size:15px; color:#00ffaa; font-weight:700; letter-spacing:.06em; text-transform:uppercase; margin-bottom:6px; }
    .line { font-size:13px; opacity:.9; line-height:1.5; }
    .barWrap { width:180px; height:9px; background:rgba(255,255,255,.14); border-radius:999px; overflow:hidden; margin:4px 0 8px; }
    .barFill { height:100%; width:100%; background:linear-gradient(90deg,#00ffaa,#ffee55); border-radius:999px; }
    #crosshair { position:fixed; left:50%; top:50%; transform:translate(-50%,-50%); width:8px; height:8px; border:1px solid rgba(255,255,255,.7); border-radius:50%; box-shadow:0 0 10px rgba(0,255,170,.8); z-index:9; pointer-events:none; }
    #message { position:fixed; left:50%; bottom:36px; transform:translateX(-50%); padding:12px 18px; border-radius:999px; background:rgba(0,0,0,.68); border:1px solid rgba(255,255,255,.18); color:#fff; font-size:14px; opacity:0; transition:opacity .25s ease; z-index:11; pointer-events:none; white-space:nowrap; }
    #message.show { opacity:1; }
    #miniMapWrap { position:fixed; left:14px; bottom:14px; width:210px; height:210px; border-radius:18px; overflow:hidden; border:1px solid rgba(0,255,170,.38); box-shadow:0 0 20px rgba(0,255,170,.22); background:rgba(0,0,0,.55); z-index:12; pointer-events:none; }
    #miniMap { width:210px; height:210px; display:block; }
    #testBadge { position:fixed; right:14px; bottom:14px; z-index:12; font-size:12px; padding:8px 10px; border-radius:999px; background:rgba(0,0,0,.6); border:1px solid rgba(0,255,170,.3); color:#baffea; pointer-events:none; }
    @media (max-width:760px){ #hud{padding:10px; flex-direction:column; gap:10px;} .panel{max-width:100%; width:100%;} .line{font-size:12px;} #message{bottom:235px; max-width:92vw; white-space:normal; text-align:center;} #miniMapWrap{width:155px;height:155px;} #miniMap{width:155px;height:155px;} #testBadge{right:10px;bottom:10px;} }
  </style>
</head>
<body>
  <div id="hud">
    <div class="panel">
      <div class="title">Aurora Stage 3.1</div>
      <div class="line"><strong>Mode:</strong> <span id="modeText">Walking</span></div>
      <div class="line"><strong>Location:</strong> <span id="districtText">Downtown</span></div>
      <div class="line"><strong>Speed:</strong> <span id="speedText">0</span></div>
      <div class="line"><strong>Nearest car:</strong> <span id="carText">None</span></div>
      <div class="line"><strong>Look mode:</strong> <span id="lookText">Drag fallback</span></div>
    </div>
    <div class="panel">
      <div class="title">Twin Tower System</div>
      <div class="line"><strong>Health:</strong> <span id="healthText">100</span>%</div>
      <div class="barWrap"><div id="healthBar" class="barFill"></div></div>
      <div class="line"><strong>Money:</strong> £<span id="moneyText">250</span></div>
      <div class="line"><strong>Wanted:</strong> <span id="wantedText">☆☆☆☆☆</span></div>
      <div class="line"><strong>Nearby:</strong> <span id="nearbyText">City grid</span></div>
    </div>
    <div class="panel">
      <div class="title">Controls</div>
      <div class="line">WASD = move / drive</div>
      <div class="line">Mouse drag = look around</div>
      <div class="line">E = enter / exit car / use door</div>
      <div class="line">Shift = sprint / boost</div>
      <div class="line">M = overview camera outside only</div>
    </div>
  </div>
  <div id="crosshair"></div>
  <div id="miniMapWrap"><canvas id="miniMap" width="210" height="210"></canvas></div>
  <div id="message">Ready</div>
  <div id="testBadge">Self-tests pending</div>

  <script type="module">
    import * as THREE from 'https://unpkg.com/three@0.160.0/build/three.module.js';

    const WORLD_SIZE = 2200, HALF_WORLD = WORLD_SIZE / 2, WATER_LEVEL = -0.06;
    let sceneMode = 'city';
    let currentInterior = null;
    let interiorFloor = 0;
    let cityReturnPosition = null;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x071019);
    scene.fog = new THREE.Fog(0x071019, 180, 1600);
    const camera = new THREE.PerspectiveCamera(68, window.innerWidth / window.innerHeight, 0.1, 4000);
    const renderer = new THREE.WebGLRenderer({ antialias:true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio,2)); renderer.setSize(window.innerWidth,window.innerHeight); renderer.shadowMap.enabled=true; renderer.shadowMap.type=THREE.PCFSoftShadowMap; document.body.appendChild(renderer.domElement);

    const miniMap=document.getElementById('miniMap'), miniCtx=miniMap.getContext('2d');
    const modeText=document.getElementById('modeText'), districtText=document.getElementById('districtText'), speedText=document.getElementById('speedText'), carText=document.getElementById('carText'), lookText=document.getElementById('lookText'), healthText=document.getElementById('healthText'), healthBar=document.getElementById('healthBar'), moneyText=document.getElementById('moneyText'), wantedText=document.getElementById('wantedText'), nearbyText=document.getElementById('nearbyText'), message=document.getElementById('message'), testBadge=document.getElementById('testBadge');

    const gameState={health:100,money:250,wanted:0,lastCollisionTime:0,collisions:0};
    let colliders=[], buildings=[], roads=[], highways=[], bridges=[], metroEntrances=[], interiorDoors=[], districts=[], interactiveZones=[];
    const cityObjects = new THREE.Group();
    const interiorObjects = new THREE.Group();
    scene.add(cityObjects); scene.add(interiorObjects); interiorObjects.visible=false;

    function showMessage(text){ message.textContent=text; message.classList.add('show'); clearTimeout(showMessage.timer); showMessage.timer=setTimeout(()=>message.classList.remove('show'),1800); }
    function mat(color,o={}){ return new THREE.MeshStandardMaterial({color,roughness:o.roughness??.82,metalness:o.metalness??0,emissive:o.emissive??0x000000,emissiveIntensity:o.emissiveIntensity??0}); }
    const mats={ grass:mat(0x18281d), islandGrass:mat(0x1e3025), water:new THREE.MeshStandardMaterial({color:0x072633,roughness:.55,metalness:.05,transparent:true,opacity:.86}), road:mat(0x11151a,{roughness:.94}), highway:mat(0x171b20,{roughness:.9}), line:mat(0xffe066,{emissive:0x665000,emissiveIntensity:.3}), pavement:mat(0x2d343a), bridge:mat(0x3e454b,{roughness:.74,metalness:.15}), tunnel:mat(0x15191f), station:mat(0x263541,{emissive:0x062033,emissiveIntensity:.25}), subwayLine:mat(0x00ffaa,{emissive:0x00ffaa,emissiveIntensity:.9}), door:mat(0xffee55,{emissive:0xffaa00,emissiveIntensity:.8}), neon:mat(0x00ffaa,{emissive:0x00ffaa,emissiveIntensity:1.4}), redNeon:mat(0xff3355,{emissive:0xff2244,emissiveIntensity:1.1}), glass:mat(0x87b8cc,{roughness:.32,metalness:.25,emissive:0x0b1e26,emissiveIntensity:.15}), towerCore:mat(0xb7c2c8,{roughness:.62,metalness:.1}), floor:mat(0x263038), wall:mat(0x58606a), carpet:mat(0x24394a), stair:mat(0x69727a), lobby:mat(0x31404c,{emissive:0x07131a,emissiveIntensity:.25}) };

    scene.add(new THREE.HemisphereLight(0x9fdcff,0x172018,1.28));
    const sun=new THREE.DirectionalLight(0xffffff,2.35); sun.position.set(260,420,160); sun.castShadow=true; sun.shadow.camera.left=-850; sun.shadow.camera.right=850; sun.shadow.camera.top=850; sun.shadow.camera.bottom=-850; sun.shadow.mapSize.width=2048; sun.shadow.mapSize.height=2048; scene.add(sun);

    function addBox(w,h,d,x,y,z,material,cast=true,receive=true,collider=false,tag='',parent=cityObjects){ const mesh=new THREE.Mesh(new THREE.BoxGeometry(w,h,d),material); mesh.position.set(x,y,z); mesh.castShadow=cast; mesh.receiveShadow=receive; mesh.userData.tag=tag; parent.add(mesh); if(collider) addCollider(mesh,w,d,tag); return mesh; }
    function addCollider(mesh,w,d,tag='',mode='city'){ colliders.push({mesh,x:mesh.position.x,z:mesh.position.z,halfX:w/2,halfZ:d/2,tag,mode}); }
    function addLand(name,x,z,w,d,material){ addBox(w,.22,d,x,0,z,material,false,true,false,name); districts.push({name,x,z,halfX:w/2,halfZ:d/2}); }

    function buildCity(){
      addBox(WORLD_SIZE,.02,WORLD_SIZE,0,WATER_LEVEL,0,mats.water,false,true,false,'water');
      addLand('Downtown Core',-250,-100,760,720,mats.grass); addLand('North Residential Borough',-330,-650,680,420,mats.grass); addLand('Industrial Docks',-360,520,760,420,mats.grass); addLand('East Island Borough',620,-20,520,640,mats.islandGrass); addLand('Airport / Service Flats',240,610,420,260,mats.grass);
      function addRoad(x,z,w,d,kind='local'){ const y=kind==='highway'?4.4:.13, h=kind==='highway'?.38:.09; const r=addBox(w,h,d,x,y,z,kind==='highway'?mats.highway:mats.road,false,true,false,kind); roads.push({x,z,w,d,kind}); if(kind==='highway')highways.push(r); return r; }
      function addRoadLine(x,z,w,d,e=false){ addBox(w,.08,d,x,e?4.65:.2,z,mats.line,false,false,false,'road-line'); }
      for(let x=-600;x<=140;x+=90){addRoad(x,-100,16,720);addRoadLine(x,-100,.45,690)} for(let z=-430;z<=260;z+=90){addRoad(-250,z,760,16);addRoadLine(-250,z,730,.45)}
      for(let x=-620;x<=-60;x+=115)addRoad(x,-650,14,410); for(let z=-820;z<=-500;z+=85)addRoad(-330,z,660,14);
      for(let x=-680;x<=-60;x+=130)addRoad(x,520,16,390); for(let z=360;z<=700;z+=90)addRoad(-360,z,730,16);
      for(let x=420;x<=810;x+=95)addRoad(x,-20,15,610); for(let z=-290;z<=240;z+=90)addRoad(620,z,500,15);
      addRoad(240,610,390,32); addRoadLine(240,610,350,.55); addRoad(-250,35,980,34,'highway'); addRoadLine(-250,35,930,.65,true); addRoad(-125,-520,34,470,'highway'); addRoadLine(-125,-520,.65,420,true); addRoad(210,360,34,520,'highway'); addRoadLine(210,360,.65,470,true); addRoad(330,35,250,34,'highway'); addRoadLine(330,35,220,.65,true); addRoad(520,35,240,34,'highway'); addRoadLine(520,35,210,.65,true);
      addBridge('East River Bridge',265,35,330,38,0); addBridge('South Service Bridge',360,360,380,24,Math.PI*.08);
      fillDistrict({name:'Downtown Core',minX:-570,maxX:100,minZ:-390,maxZ:230,stepX:70,stepZ:70,baseH:28,hRand:74,palette:[mat(0x27384a),mat(0x344153),mat(0x243642),mat(0x3e3c49)],enterableEvery:9,skipTwin:true});
      fillDistrict({name:'North Residential Borough',minX:-590,maxX:-90,minZ:-795,maxZ:-520,stepX:75,stepZ:65,baseH:10,hRand:26,palette:[mat(0x55382f),mat(0x4b4135),mat(0x31483a),mat(0x4f4d44)],enterableEvery:5});
      fillDistrict({name:'Industrial Docks',minX:-650,maxX:-80,minZ:385,maxZ:680,stepX:95,stepZ:80,baseH:12,hRand:24,palette:[mat(0x3f474b),mat(0x514a3d),mat(0x334049),mat(0x4a3b34)],enterableEvery:4});
      fillDistrict({name:'East Island Borough',minX:420,maxX:820,minZ:-270,maxZ:230,stepX:75,stepZ:75,baseH:14,hRand:45,palette:[mat(0x394f5c),mat(0x533d56),mat(0x365344),mat(0x584c39)],enterableEvery:5});
      for(let i=0;i<8;i++)addBox(42,5,12,-665+i*75,2.7,745,mats.bridge,true,true,false,'dock-pier'); addBox(150,26,70,215,13,700,mat(0x303943),true,true,true,'airport-hangar'); addBox(70,38,48,375,19,670,mat(0x29333d),true,true,true,'airport-terminal');
      addMetroEntrance('Central Metro',-250,-55,0); addMetroEntrance('North Metro',-330,-620,Math.PI/2); addMetroEntrance('Docklands Subway',-455,520,0); addMetroEntrance('Island Metro',620,-65,Math.PI/2); addMetroEntrance('Airport Metro',305,610,0);
      addSubwayTunnel(-250,-335,9,570); addSubwayTunnel(-250,-55,760,9); addSubwayTunnel(185,-65,880,9); addSubwayTunnel(620,-65,9,430); addSubwayTunnel(-455,235,9,570);
      buildTwinTowers(); addNeonSigns();
    }

    function addBridge(name,x,z,w,d,rot=0){ const group=new THREE.Group(); group.position.set(x,5.1,z); group.rotation.y=rot; const deck=new THREE.Mesh(new THREE.BoxGeometry(w,.55,d),mats.bridge); deck.castShadow=true; deck.receiveShadow=true; group.add(deck); const railL=new THREE.Mesh(new THREE.BoxGeometry(w,1.2,1.1),mats.bridge); railL.position.z=d/2-1; railL.position.y=.75; group.add(railL); const railR=railL.clone(); railR.position.z=-d/2+1; group.add(railR); for(let i=-w/2+35;i<=w/2-35;i+=70){ const p=new THREE.Mesh(new THREE.BoxGeometry(2.4,15,2.4),mats.bridge); p.position.set(i,7,d/2-4); group.add(p); const p2=p.clone(); p2.position.z=-d/2+4; group.add(p2);} cityObjects.add(group); bridges.push({name,group,x,z,w,d,rot}); }
    function pointNearRoad(x,z,pad){ return roads.some(r=>Math.abs(x-r.x)<r.w/2+pad&&Math.abs(z-r.z)<r.d/2+pad); }
    function addBuilding(x,z,w,d,h,material,district,enterable=false){ addBox(w+8,.18,d+8,x,.18,z,mats.pavement,false,true,false,'pavement'); const b=addBox(w,h,d,x,h/2+.28,z,material,true,true,true,district); b.userData.district=district; b.userData.enterable=enterable; buildings.push(b); if(enterable){ const doorZ=z-d/2-.6; const door=addBox(3.6,4.2,.35,x,2.35,doorZ,mats.door,false,false,false,'interior-door'); interiorDoors.push({door,x,z:doorZ,district,building:b,type:'generic'});} return b; }
    function fillDistrict(o){ let idx=0; for(let x=o.minX;x<=o.maxX;x+=o.stepX){ for(let z=o.minZ;z<=o.maxZ;z+=o.stepZ){ if(o.skipTwin&&x>-390&&x<-110&&z>-260&&z<40)continue; if(Math.abs((x%90+90)%90)<18||Math.abs((z%90+90)%90)<18)continue; if(pointNearRoad(x,z,13))continue; const w=o.stepX*(.42+Math.random()*.18), d=o.stepZ*(.42+Math.random()*.18), h=o.baseH+Math.random()*o.hRand; addBuilding(x,z,w,d,h,o.palette[idx%o.palette.length],o.name,idx%o.enterableEvery===0); idx++; } } }
    function addMetroEntrance(name,x,z,rot=0){ const group=new THREE.Group(); group.position.set(x,.35,z); group.rotation.y=rot; const base=new THREE.Mesh(new THREE.BoxGeometry(16,1.2,10),mats.station); base.position.y=.6; group.add(base); const stair=new THREE.Mesh(new THREE.BoxGeometry(8,.7,13),mats.tunnel); stair.position.set(0,.55,-5); group.add(stair); const sign=new THREE.Mesh(new THREE.BoxGeometry(13,4,.5),mats.subwayLine); sign.position.set(0,4,4.8); group.add(sign); cityObjects.add(group); metroEntrances.push({name,group,x,z,rot}); }
    function addSubwayTunnel(x,z,w,d){ addBox(w,.35,d,x,-2.2,z,mats.tunnel,false,false,false,'subway-tunnel'); addBox(w>d?w:.45,.12,d>=w?d:.45,x,-1.9,z,mats.subwayLine,false,false,false,'subway-route'); }

    function buildTwinTowers(){
      const plaza = addBox(250,.24,170,-250,.28,-115,mats.pavement,false,true,false,'twin-tower-plaza');
      addBox(245,.14,8,-250,.45,-28,mats.line,false,false,false,'plaza-front-line');
      createTowerShell('Tower A',-310,-130,58,58,230);
      createTowerShell('Tower B',-190,-130,58,58,230);
      addBox(126,10,14,-250,132,-130,mats.bridge,true,true,false,'skybridge-placeholder');
      addBox(22,9,20,-310,4.8,-162,mats.lobby,true,true,false,'tower-a-entrance');
      addBox(22,9,20,-190,4.8,-162,mats.lobby,true,true,false,'tower-b-entrance');
      const doorA=addBox(7,6,.6,-310,3.4,-172,mats.door,false,false,false,'tower-a-door');
      const doorB=addBox(7,6,.6,-190,3.4,-172,mats.door,false,false,false,'tower-b-door');
      interiorDoors.push({door:doorA,x:-310,z:-172,district:'Twin Towers',building:null,type:'tower',tower:'A'});
      interiorDoors.push({door:doorB,x:-190,z:-172,district:'Twin Towers',building:null,type:'tower',tower:'B'});
      interactiveZones.push({type:'tower-door',x:-310,z:-172,radius:8,tower:'A'}); interactiveZones.push({type:'tower-door',x:-190,z:-172,radius:8,tower:'B'});
    }
    function createTowerShell(name,x,z,w,d,h){
      addBox(w,h,d,x,h/2+.3,z,mats.glass,true,true,true,name);
      addBox(7,h+8,7,x,h/2+4,z,mats.towerCore,true,true,true,`${name} central core`);
      for(let y=18;y<h;y+=18) addBox(w+1,.55,d+1,x,y,z,mats.line,false,false,false,`${name} floor band`);
      for(let ix=-1;ix<=1;ix+=2){ addBox(1.1,h+4,1.1,x+ix*w/2,yClamp(h/2+2),z,mats.towerCore,true,true,false,`${name} corner rib`); addBox(1.1,h+4,1.1,x+ix*w/2,yClamp(h/2+2),z+d/2,mats.towerCore,true,true,false,`${name} corner rib`); }
      function yClamp(v){return v+.3}
      buildings.push({position:{x,z},userData:{district:'Twin Towers',enterable:true,tower:name}});
    }

    function addNeonSigns(){ for(let i=0;i<65;i++){ const b=buildings[Math.floor(Math.random()*buildings.length)]; if(!b||!b.position||b.userData?.tower)continue; const c=b.position; addBox(7+Math.random()*8,.22,1,c.x,5+Math.random()*18,c.z-7,Math.random()>.72?mats.redNeon:mats.neon,false,false,false,'neon-sign'); } }

    buildCity();

    const player=new THREE.Group(); const body=new THREE.Mesh(new THREE.CapsuleGeometry(.55,1.05,6,12),mat(0x00ffaa,{emissive:0x003322,emissiveIntensity:.4})); body.position.y=1.15; body.castShadow=true; player.add(body); player.position.set(-310,.25,-182); scene.add(player);
    function createCar(x,z,color){ const car=new THREE.Group(); const mainMat=mat(color,{roughness:.55,metalness:.2}), darkMat=mat(0x07090b,{roughness:.6}); const cb=new THREE.Mesh(new THREE.BoxGeometry(3.6,.9,6),mainMat); cb.position.y=.75; cb.castShadow=true; car.add(cb); const cabin=new THREE.Mesh(new THREE.BoxGeometry(2.5,.8,2.4),darkMat); cabin.position.set(0,1.35,-.45); cabin.castShadow=true; car.add(cabin); const wheelGeo=new THREE.CylinderGeometry(.45,.45,.38,18); [[-1.85,.45,2],[1.85,.45,2],[-1.85,.45,-2],[1.85,.45,-2]].forEach(([wx,wy,wz])=>{const wheel=new THREE.Mesh(wheelGeo,darkMat); wheel.rotation.z=Math.PI/2; wheel.position.set(wx,wy,wz); wheel.castShadow=true; car.add(wheel);}); car.position.set(x,.25,z); car.rotation.y=Math.random()*Math.PI*2; car.userData={speed:0,steering:0,occupied:false,health:100}; cityObjects.add(car); return car; }
    const cars=[createCar(-210,-45,0xff3355),createCar(-350,-180,0x3388ff),createCar(-120,110,0xffcc33),createCar(610,-40,0xffffff),createCar(690,160,0x9b5cff),createCar(-460,540,0xff8833),createCar(230,610,0x66eeff),createCar(-125,-520,0xdddddd)];

    function clearInterior(){ while(interiorObjects.children.length) interiorObjects.remove(interiorObjects.children[0]); colliders=colliders.filter(c=>c.mode!=='interior'); interactiveZones=interactiveZones.filter(z=>z.sceneMode!=='interior'); }
    function enterTower(tower){ if(mode==='driving') return showMessage('Exit the car before entering tower'); cityReturnPosition=player.position.clone(); sceneMode='interior'; currentInterior=`Tower ${tower}`; interiorFloor=0; overviewCamera=false; cityObjects.visible=false; interiorObjects.visible=true; clearInterior(); buildTowerInterior(tower,interiorFloor); player.position.set(0,.25,38); yaw=Math.PI; showMessage(`Entered Tower ${tower} lobby`); }
    function exitInterior(){ sceneMode='city'; cityObjects.visible=true; interiorObjects.visible=false; clearInterior(); currentInterior=null; player.position.copy(cityReturnPosition||new THREE.Vector3(-310,.25,-182)); yaw=0; showMessage('Exited to city plaza'); }
    function changeFloor(dir){
      if(sceneMode!=='interior')return;
      interiorFloor=THREE.MathUtils.clamp(interiorFloor+dir,-1,12);
      clearInterior();
      buildTowerInterior(currentInterior.includes('A')?'A':'B',interiorFloor);
      player.position.set(-28,.25,24);
      showMessage(`${currentInterior} ${floorLabel(interiorFloor)}`);
    }

    function floorLabel(floor){
      if(floor===-1)return 'Basement Parking';
      if(floor===0)return 'Lobby';
      if(floor===1)return 'Admin Floor';
      if(floor===2)return 'Conference Floor';
      if(floor===3)return 'Open Office Floor';
      if(floor===4)return 'Finance Floor';
      if(floor===5)return 'IT / Server Floor';
      if(floor===6)return 'Legal Records Floor';
      if(floor===7)return 'Executive Floor';
      if(floor===8)return 'Maintenance Floor';
      if(floor===9)return 'Observation Floor';
      if(floor===10)return 'Skybridge Plant Room';
      if(floor===11)return 'Penthouse Office';
      if(floor===12)return 'Rooftop';
      return `Floor ${floor}`;
    }

    function buildTowerInterior(tower,floor){
      const label=floorLabel(floor);
      addInteriorShell(label);
      addCoreSystems();
      addNavigationZones();

      if(floor===-1) addBasementParking(tower);
      else if(floor===0) addLobbyFloor(tower);
      else if(floor===1) addAdminFloor(tower);
      else if(floor===2) addConferenceFloor(tower);
      else if(floor===3) addOpenOfficeFloor(tower);
      else if(floor===4) addFinanceFloor(tower);
      else if(floor===5) addServerFloor(tower);
      else if(floor===6) addRecordsFloor(tower);
